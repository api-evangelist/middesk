{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/middesk/main/json-schema/monitor.json",
  "title": "Monitor",
  "type": "object",
  "properties": {
    "object": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "event_types": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/type_:MonitorEventTypesItem"
      }
    }
  },
  "required": [
    "object",
    "id",
    "created_at",
    "event_types"
  ]
}